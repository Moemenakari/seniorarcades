# ============================================================
# .gitignore — NLG Arcade Hub
# ============================================================

# ── Dependencies ──
node_modules/
frontend/node_modules/
admin/node_modules/
backend/node_modules/

# ── Production Builds ──
dist/
build/
frontend/dist/
frontend/build/
admin/dist/
admin/build/

# ── Environment Variables (NEVER commit secrets) ──
.env
.env.local
.env.production
backend/.env
frontend/.env
admin/.env

# ── SQLite Database Files ──
data/
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
backend/data/

# ── IDE / Editor Files ──
.vscode/
.idea/
*.swp
*.swo

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Coverage ──
coverage/
.nyc_output/
