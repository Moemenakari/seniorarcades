# ============================================================
# NLG ARCADE HUB — BACKEND ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# ── Server ──
PORT=5000
NODE_ENV=development

# ── Authentication ──
# Use a long, random string in production (min 32 chars)
JWT_SECRET=super_secret_admin_key_for_next_level_game_change_in_production

# ── Database (SQLite) ──
# Leave empty to use default path: /data/nlg_arcade.db (relative to project root)
# On Render.com: set to /opt/render/project/src/data
DB_PATH=

# ── CORS ──
# Comma-separated list of allowed origins in production.
# Leave empty to allow all origins (development mode).
# Example: https://your-frontend.vercel.app,https://your-admin.vercel.app
ALLOWED_ORIGINS=
